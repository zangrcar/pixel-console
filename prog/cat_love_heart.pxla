; Largest heart: the cat disappears and one centred heart remains.
; Four slower phases loop for about ten seconds. The full-screen confetti
; uses all four frames and moves down one extra pixel in each phase.
setv 2 10
finale:
clear 0
mode 1
origin 0 0
spr 0 0 127 0
origin 0 0
spr 32 0 79 0
mode 0
font 0 1
text 61 18 "I"
text 52 28 "love"
text 55 38 "you"
frame 15
clear 0
mode 1
origin 0 1
spr 0 0 127 1
origin 0 0
spr 32 0 79 0
mode 0
font 0 1
text 61 18 "I"
text 52 28 "love"
text 55 38 "you"
frame 15
clear 0
mode 1
origin 0 2
spr 0 0 127 2
origin 0 0
spr 32 0 79 0
mode 0
font 0 1
text 61 18 "I"
text 52 28 "love"
text 55 38 "you"
frame 15
clear 0
mode 1
origin 0 3
spr 0 0 127 3
origin 0 0
spr 32 0 79 0
mode 0
font 0 1
text 61 18 "I"
text 52 28 "love"
text 55 38 "you"
frame 15
djnz 2 finale
end
