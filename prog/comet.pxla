; Repeating moving star field using the built-in STAR sprite.

loop:
clear 0
mode 1
spr 88 0 STAR 0
spr 48 20 STAR 0
spr 8 32 STAR 0
frame 4

clear 0
spr 72 0 STAR 0
spr 32 20 STAR 0
spr 96 32 STAR 0
frame 4

clear 0
spr 56 0 STAR 0
spr 16 20 STAR 0
spr 80 32 STAR 0
frame 4

clear 0
spr 40 0 STAR 0
spr 0 20 STAR 0
spr 64 32 STAR 0
frame 4

jmp loop
